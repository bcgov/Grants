{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=ApplicantPortal;Username=postgres;Password=admin;Port=5432",
    "Redis": "localhost:6379,password=password,defaultDatabase=1,abortConnect=false"
    // For Redis Sentinel configuration, use this format instead:
    // "Redis": "sentinel1:26379,sentinel2:26379,sentinel3:26379,serviceName=mymaster,defaultDatabase=1,abortConnect=false"
    // Or with authentication:
    // "Redis": "sentinel1:26379,sentinel2:26379,sentinel3:26379,serviceName=mymaster,defaultDatabase=1,password=yourpassword,abortConnect=false"
  },
  "ProfileCache": {
    "CacheKeyPrefix": "profile:",
    "CacheExpiryMinutes": 60,
    "SlidingExpiryMinutes": 15
  },
  "Keycloak": {
    "AuthServerUrl": "https://your-keycloak-server.com/auth",
    "Realm": "your-realm",
    "SslRequired": true,
    "Resource": "your-client-id",
    "ConfidentialPort": 0,
    "Credentials": {
      "Secret": "your-client-secret-here"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "log.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Database": {
    "RunMigrationsOnStartup": false,
    "SeedDataOnStartup": false
  },
  "Messaging": {
    "RabbitMQ": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "guest",
      "Password": "guest",
      "VirtualHost": "/",
      "UseSsl": false,
      "ConnectionTimeout": "00:00:30",
      "RetryCount": 3,
      "RetryDelay": "00:00:30"
    },
    "Outbox": {
      "PollingIntervalSeconds": 15,
      "BatchSize": 100,
      "MaxRetries": 3,
      "RetentionDays": 30,
      "CleanupIntervalHours": 24
    },
    "Inbox": {
      "PollingIntervalSeconds": 15,
      "BatchSize": 50,
      "MaxRetries": 3,
      "RetentionDays": 30,
      "CleanupIntervalHours": 24
    },
    "DistributedLocks": {
      "DefaultTimeoutMinutes": 5,
      "RenewalIntervalMinutes": 2,
      "WaitTimeoutSeconds": 5
    },
    "BackgroundJobs": {
      "MaxConcurrency": 3,
      "Enabled": true,
      "MisfireThresholdSeconds": 60
    }
  },
  "Plugins": {
    "DEMO": {
      "Enabled": true,
      "Features": [ "ProfilePopulation", "ContactManagement", "AddressManagement", "OrganizationManagement" ],
      "Configuration": {
        "BaseUrl": "https://demo-plugin-endpoint.com",
        "ApiKey": "your-demo-api-key",
        "TimeoutSeconds": 30,
        "MaxRetryAttempts": 3,
        "EnableCircuitBreaker": true,
        "Headers": {
          "User-Agent": "Grants-ApplicantPortal/1.0"
        }
      }
    },
    "UNITY": {
      "Enabled": true,
      "Features": [ "ProfilePopulation", "ContactManagement", "AddressManagement", "OrganizationManagement" ],
      "Configuration": {
        "BaseUrl": "https://unity-plugin-endpoint.com",
        "ApiKey": "your-unity-api-key",
        "TimeoutSeconds": 45,
        "MaxRetryAttempts": 2,
        "EnableCircuitBreaker": true,
        "Headers": {
          "User-Agent": "Grants-ApplicantPortal/1.0",
          "Accept": "application/json"
        }
      }
    }
  }
}
