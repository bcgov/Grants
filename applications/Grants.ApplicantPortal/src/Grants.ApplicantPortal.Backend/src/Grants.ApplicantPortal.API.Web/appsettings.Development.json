{
  "ConnectionStrings": {
    "Grants": "Host=localhost;Database=ApplicantPortal;Username=postgres;Password=admin;Port=5432"
  },
  "ProfileCache": {
    "CacheKeyPrefix": "profile:",
    "CacheExpiryMinutes": 60,
    "SlidingExpiryMinutes": 15
  },
  "Database": {
    "RunMigrationsOnStartup": false,
    "SeedDataOnStartup": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Keycloak": {
    "AuthServerUrl": "https://dev.loginproxy.gov.bc.ca/auth",
    "Realm": "your-realm",
    "Resource": "your-client-id"
  },
  "Frontend": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:3000",
      "http://localhost:8080",
      "https://dev-grants-portal.gov.bc.ca"
    ]
  },
  "Plugins": {
    "DEMO": {
      "Enabled": true,      
      "Configuration": {
        "BaseUrl": "https://demo-plugin-endpoint.com",
        "ApiKey": "your-demo-api-key",
        "TimeoutSeconds": 30,
        "MaxRetryAttempts": 3,
        "EnableCircuitBreaker": true,
        "Headers": {
          "User-Agent": "Grants-ApplicantPortal/1.0"
        }
      }
    },
    "UNITY": {
      "Enabled": true,      
      "Configuration": {
        "BaseUrl": "http://localhost:5555",
        "ApiKey": "dev-unity-api-key",
        "AuthHeaderName": "X-Api-Key",
        "TimeoutSeconds": 45,
        "MaxRetryAttempts": 2,
        "EnableCircuitBreaker": true,
        "Headers": {
          "User-Agent": "Grants-ApplicantPortal/1.0",
          "Accept": "application/json"
        }
      }
    }
  }
}